{
  "name": "foilio",
  "version": "0.0.1",
  "private": true,
  "description": "Foilio — Pokemon TCG collection showcase mobile app.",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "mobile": "pnpm --filter @foilio/mobile",
    "ui": "pnpm --filter @foilio/ui",
    "seed": "tsx scripts/seed.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@supabase/supabase-js": "^2.106.1",
    "lefthook": "1.10.0",
    "tsx": "^4.22.3",
    "turbo": "2.5.6",
    "typescript": "5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@sentry/cli",
      "@shopify/react-native-skia",
      "lefthook",
      "msgpackr-extract"
    ],
    "patchedDependencies": {
      "@supabase/supabase-js@2.106.1": "patches/@supabase__supabase-js@2.106.1.patch"
    }
  }
}
