# Foilio mobile env vars.
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit credentials.
#
# Note: Expo only exposes vars prefixed with EXPO_PUBLIC_ to client code.
# Anything else stays server-side (Edge Functions).

# Supabase
# Find these at: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Google OAuth (browser-based via expo-auth-session)
# Get this from Google Cloud Console after creating an OAuth Web Client.
# See OAUTH_SETUP.md §2 for the full setup walkthrough.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxx.apps.googleusercontent.com

# Sentry (Phase 0 Week 2 — add when SDK is wired)
# EXPO_PUBLIC_SENTRY_DSN=

# PostHog (Phase 0 Week 2 — add when SDK is wired)
# EXPO_PUBLIC_POSTHOG_API_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
